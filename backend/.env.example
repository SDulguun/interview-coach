# Copy to .env and fill in values. .env is gitignored.

# Anthropic API key for LLM-generated sample answers + improvements.
# If unset, the breakdown endpoint falls back to deterministic rule-based
# templates (no network calls). The app stays fully functional without it.
ANTHROPIC_API_KEY=

# Optional override; defaults to the latest Sonnet.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Disable Whisper STT loading at startup (set on Linux/cloud deploys where
# faster-whisper isn't installed and the model isn't present). Voice input
# from the frontend will be hidden via VITE_DISABLE_VOICE instead.
DISABLE_WHISPER=

# Disable Core ML embedding loading (coremltools is macOS-only). When set,
# relevance scoring falls back to TF-IDF + keyword matching.
DISABLE_COREML=

# Comma-separated list of allowed origins for CORS. Leave blank to allow
# any localhost port (dev default). Set to your Vercel URL in production.
# Example: CORS_ORIGINS=https://interview-coach-mn.vercel.app
CORS_ORIGINS=
