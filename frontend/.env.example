# Copy to .env (or .env.local) and adjust for your environment.

# Base URL of the FastAPI backend. Defaults to localhost when unset.
# Production: set this to your deployed Render URL.
VITE_API_BASE_URL=http://localhost:8000

# Hide the voice/STT input tab in the session UI. Use "true" on cloud
# deploys where the backend has no Whisper STT (text input still works).
VITE_DISABLE_VOICE=false
